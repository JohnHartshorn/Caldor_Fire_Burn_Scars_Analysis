/// Center the map over the location of the Caldera Fire
Map.setCenter(-120.3, 38.7000, 10);

///Define region of interest

var CaldorFire = ee.Geometry.Polygon(
        [[[-120.64675598144531, 38.95622510781989],
          [-120.62341003417968, 38.42133838578212],
          [-119.80080871582031, 38.429945244340935],
          [-119.89144592285156, 38.97330956860997]]]);
          
          
//
//
//
//
//Import Landsat Image for 09/06/2021
//Post fire
//
//
//
//

var PostFire = ee.Image('LANDSAT/LC09/C02/T1/LC09_043033_20211121')
    .select("B1","B2","B3","B4","B5", "B6", "B7");


/////Select bands to be used

var bands = ['B1', 'B2', 'B3', 'B4', 'B5', 'B6'];


print("Post Fire image", PostFire);

//subset PostFire to area of interest

var PostFire = PostFire.clip(CaldorFire);

  
//display a color composite of Landsat 8 bands 543, stretched between DN 0 and 200 to improve the visualization
Map.addLayer(PostFire, {bands: ['B4', 'B3', 'B2'], min: 4809, max: 9219}, "Post Fire"); 

Map.addLayer(PostFire, {bands: ['B5', 'B4', 'B3'], min: 3594, max: 11490}, "Post Fire Infrared"); 



///
///
///
///

//Supervised classifications for BF

///
///
///

// Make the training dataset by randomly sampling 1000 pixels from the image

var training = PostFire.sample({
  region: CaldorFire,
  scale: 30,
  numPixels: 1000
});

//Print and study the variable training:

print("trainingPostFire",training);


// Instantiate the clusterer and train it.

var clustererPostFire = ee.Clusterer.wekaKMeans(10).train(training);


// Cluster the input using the trained clusterer.

var clusteredPostFire = PostFire.cluster(clustererPostFire);
print('clusteredPostFire',clusteredPostFire);



// Display the clusters with a custom palette

Map.addLayer(clusteredPostFire, {palette: ['red', 'DFDBC2', '53B00C','1c9099', '0244BE', '60423F','1c9099', '35432A', '35432A', 'ece2f0'], min:1, max:10}, 'clustered',false);





//
//
//
//Classified for BF
//merge feature collections
//
//
//



var samplePostFireFC = Water.merge(Urban).merge(Forest).merge(CutForest).merge(BareSoil).merge(BurnScars);
var trainingPostFireFC = samplePostFireFC;

// Add a column of random numbers to split the training points by 70%/30% 

var samplePostFireFC=samplePostFireFC.randomColumn();


var split = 0.7;  // Split the sample 70% training, 30% testing.
var trainingPostFireFC = samplePostFireFC.filter(ee.Filter.lt('random', split));
print(trainingPostFireFC,'Training points for classifierPostFireFC');   //points for classifier answer: 569 elements, 1 column
var validationPostFireFC = samplePostFireFC.filter(ee.Filter.gte('random', split));
print(validationPostFireFC,'Validation pointsPostFireFC');     


// Get the values for all pixels in each polygon in the training.

var trainingPostFire = PostFire.select(bands).sampleRegions({

  // Get the sample from the polygons FeatureCollection.

  collection: trainingPostFireFC,

  // Keep this list of properties from the polygons.

  properties: ['class'],

  // Set the scale to get Landsat pixels in the polygons.

  scale: 30
});
print('trainingPostFire', trainingPostFire);


//  Train a minimum distance classifier

var MDclassifier = ee.Classifier.minimumDistance("euclidean").train({
features: trainingPostFire, 
  classProperty: 'class', 
  inputProperties: bands
});

// Classify the input imagery.

var MDclassified = PostFire.select(bands).classify(MDclassifier);

// Display the clusters with random colors. The first three bands of the output image will contain 8-bit R, G and B values, 
// followed by the band of the clustered image.

Map.addLayer(MDclassified.randomVisualizer(), {}, 'MD clustersPostFire', false);



/* Train a random forest classifier

 A random forest classifier uses a combination of
decision tree classifiers where each is generated using a random vector sampled independently
from the input vector. Each tree casts a unit vote for the most popular class to classify an input
vector . */
var RFclassifier = ee.Classifier.smileRandomForest(100) //set the number of trees in random forest to 100
.train(trainingPostFire, 'class', bands); 

// Classify the input imagery with the Random Forest classifier
var RFclassified = PostFire.select(bands).classify(RFclassifier);


// Display the clusters with random colors. The first three bands of the output image will contain 8-bit R, G and B values, 
// followed by the band of the clustered image.
Map.addLayer(RFclassified.randomVisualizer(), {}, 'RF clustersPostFire', false);

//
//
//
//

// Get the values for all pixels in each polygon in the validation.
var MDvalidation = MDclassified.sampleRegions({

  // Get the sample from the polygons FeatureCollection.
  collection: validationPostFireFC,

  // Keep this list of properties from the polygons.
  properties: ['class'],

  // Set the scale to get Landsat pixels in the polygons.
  scale: 30
});
print("MDvalidationPostFire",MDvalidation);


// Compare the landcover of your validation data against the classification result
var MDvalidationAccuracy = MDvalidation.errorMatrix('class', 'classification');
//Print the error matrix to the console
print('MD Error matrixPostFire: ', MDvalidationAccuracy);
//Print the overall accuracy to the console
print('MD Overall accuracyPostFire: ', MDvalidationAccuracy.accuracy());
// Print the kappa coefficient
print('MD kappaPostFire: ', MDvalidationAccuracy.kappa());
// Print the User's accuracy
print('MD consumersAccuracy()PostFire', MDvalidationAccuracy.consumersAccuracy());
// Print the Producer's accuracy
print('MD producersAccuracy()PostFire', MDvalidationAccuracy.producersAccuracy());


//Repeat for RandomForest
// Get the values for all pixels in each polygon in the validation.
var RFvalidation = RFclassified.sampleRegions({
  // Get the sample from the polygons FeatureCollection.
  collection: validationPostFireFC,
  // Keep this list of properties from the polygons.
  properties: ['class'],
  // Set the scale to get Landsat pixels in the polygons.
  scale: 30
});
print("RFvalidationPostFire",RFvalidation);


// Compare the landcover of your validation data against the classification result
var RFvalidationAccuracy = RFvalidation.errorMatrix('class', 'classification');
//Print the error matriPostFire ', RFvalidationAccuracy);
//Print the overall accuracy to the console
print('RF Overall accuracy:PostFire ', RFvalidationAccuracy.accuracy());
// Print the kappa coefficient
print('RF kappa:PostFire ', RFvalidationAccuracy.kappa());
// Print the User's accuracy
print('RF consumersAccuracy()PostFire', RFvalidationAccuracy.consumersAccuracy());
// Print the Producer's accuracy
print('RF producersAccuracy()PostFire', RFvalidationAccuracy.producersAccuracy());


//Query the map: click on the Inspector tab, on the top of the right window. A cross cursor will allow 
//you to query the map when you click on it. Explore the classes.
//Show only one class, 
//var oneclass = BeforeFire.select("cluster").eq(5).selfMask(); //.selfMask() hides all the pixels that don't match the criterion
//Map.addLayer(oneclass,{},"oneclass");


// Add a white background to the image
// Create an empty image into which to paint white
Map.addLayer(ee.Image(1), {palette:['ffffff']}, 'white',false);  //false indicates that the image will not be loaded by default
// select the image 'white' in the Layers pull down menu



var colortable=['0000FF', '00FF00', '000000', '964B00', '808080', 'FF0000'];
//Replace class 0, 1, 2… with the labels you have identified
var names=['Water', 'Forest', 'BareRock', 'Deforestation', 'BareSoil/Urban'];


Map.addLayer(RFclassified,{palette: colortable, min:1, max:10},"final result RFPostFire");


Map.addLayer(MDclassified,{palette: colortable, min:1, max:10},"final result MDPosttFire", false);



///
