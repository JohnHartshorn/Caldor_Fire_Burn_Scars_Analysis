//Add a Legend to your map
// Create the panel for the legend items.
var legend = ui.Panel({
  style: {
    position: 'bottom-left',
    padding: '8px 40px'
  }
});

// Create and add the legend title.
var legendTitle = ui.Label({
  value: 'Post Caldor Fire',
  style: {
    fontWeight: 'bold',
    fontSize: '18px',
 margin: '0 0 4px 0',
    padding: '0'
  }
});
legend.add(legendTitle);


var loading = ui.Label('Legend', {margin: '2px 0 4px 0'});
legend.add(loading);


// Creates and styles 1 row of the legend.
var makeRow = function(color, name) {
  // Create the label that is actually the colored box.
  var colorBox = ui.Label({
    style: {
      backgroundColor: '#' + color,
      // Use padding to give the box height and width.
      padding: '8px',
      margin: '0 0 4px 0'
    }
  });


  // Create the label filled with the description text.
  var description = ui.Label({
    value: name,
    style: {margin: '0 0 4px 6px'}
  });


  return ui.Panel({
    widgets: [colorBox, description],
    layout: ui.Panel.Layout.Flow('horizontal')
  });
};


// Get the list of palette colors and class names from the image.
RFclassified.toDictionary().evaluate(function(result) {
  loading.style().set('shown', true);


  for (var i = 0; i < names.length; i++) {
    legend.add(makeRow(colortable[i], names[i]));
  }
});


// Add the legend to the map.
Map.add(legend);


// Export the classified image to Google Drive
// First, make sure that you are zoomed out to the full extent of the map. The exported crop area will match what you are visualizing.
// Set the visualization parameters and create a task that you can Run from the Tasks tab.
var viz = { min:0, max:9, palette:colortable
};
Export.image.toDrive({
  image: RFclassified.visualize(viz),
  description: 'FinalExportPF',
  folder: 'GIST58_Lab5',
region: CaldorFire,
  scale: 30
});
